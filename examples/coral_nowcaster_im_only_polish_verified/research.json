    "results_dir": ".research/runs"
  },
  "evaluator": {
    "type": "command",
    "command": "bash -c 'cd /home/datision/projects/molcia_ia/agts && /home/datision/projects/molcia_ia/.venv/bin/python examples/coral_nowcaster_im_only_polish_verified/solution.py --predict examples/coral_nowcaster_im_only_polish_verified/seed/eval/answers/hidden_eval_features.csv.gz --out /tmp/hidden_eval_predictions.csv && /home/datision/projects/molcia_ia/.venv/bin/python examples/coral_nowcaster_im_only_polish_verified/eval.py'",
    "timeout": 120,
    "direction": "minimize",
    "private_paths": [
      "examples/coral_nowcaster_im_only_polish_verified/seed/eval/answers"

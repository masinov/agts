{
  "task": {
    "name": "coral_nowcaster_im_only_polish_verified",
    "description": "Fineness nowcaster experiment using PBM features from im_only_polish.json, matching CORAL experiment coral_nowcaster_im_only_polish_verified. Train models on train_samples.csv.gz + dev_samples.csv.gz, predict hidden_eval_features.csv.gz. Baseline hidden RMSE: 2.8748.",
    "objective": "minimize hidden_eval_rmse"

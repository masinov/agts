{
  "task": {
    "name": "knapsack-heuristic-optimization",
    "description": "Improve solver.py for 0/1 knapsack instances. The solver receives JSON instances with item weights, values, and capacity, and must output selected original item indices. Optimize total value while keeping every solution feasible. Public instances are visible in benchmarks/knapsack/public_instances.json; the evaluator scores on a private set.",
    "objective": "maximize score = candidate_value / optimal_value - small runtime penalty"
  },
  "workspace": {
    "seed_path": "benchmarks/knapsack/seed",
    "results_dir": ".research/runs"
  },
  "evaluator": {
    "type": "command",
    "command": "python /home/datision/projects/agts/benchmarks/knapsack/eval.py",
    "final_command": "python /home/datision/projects/agts/benchmarks/knapsack/eval.py",
    "timeout": 20,
    "direction": "maximize",
    "private_paths": [
      "benchmarks/knapsack/private_instances.json"
    ],
    "holdout_paths": [
      "benchmarks/knapsack/final_instances.json"
    ]
  },
  "agents": {
    "runtime": "claude_code",
    "model": "minimax-2.7",
    "max_agents": 3,
    "max_turns": 80,
    "launch": false,
    "sandbox": true,
    "sandbox_backend": "bwrap",
    "roles": [
      "research_worker",
      "implementation_worker",
      "distillation_worker"
    ]
  },
  "workers": {
    "local_agts": {
      "enabled": true,
      "mode": "optional",
      "max_steps": 3,
      "before_eval": true,
      "after_failed_eval": true,
      "before_pivot": true
    }
  },
  "search": {
    "max_branches": 4,
    "max_active_branches": 2,
    "max_agents_per_branch": 2,
    "max_evals": 20,
    "split_threshold": 0.62,
    "stop_threshold": 0.18,
    "verify_before_finalize": true
  },
  "heartbeat": {
    "reflect_every": 1,
    "consolidate_every": 4,
    "pivot_after_stall": 3
  }
}
